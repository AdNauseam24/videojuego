  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a7542fd98a6c7a64992f0fe42f2fb690, type: 3}
  m_Name: Cap3_Pueblo1_NOAyudado y Primero
  m_EditorClassIdentifier: 
  lineas:
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Vaya, si eres t\xFA"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "A pesar de que nos dejaste tirados la \xFAltima vez parece que has vuelto"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Tengo una cosa interesante para ti
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Que seguro que har\xE1 que esta vez decidas ayudarnos a nosotros"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Ver\xE1s, vino una se\xF1ora anciana y nos pidi\xF3 que te di\xE9semos
      estos dos amuletos, as\xED que eso vamos a hacer"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Ahora podemos pedirte un favor
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Ver\xE1s, queremos celebrar un gran festival, y para ello vamos a necesitar
      tu ayuda"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Necesitamos que nos traigas 300 de oro y 50 flores rojas or favor
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Te estar\xEDamos eternamente agradecidos"
  opciones: []
  requisitoNPCs: []
