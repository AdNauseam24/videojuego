  m_Script: {fileID: 11500000, guid: a7542fd98a6c7a64992f0fe42f2fb690, type: 3}
  m_Name: Cap3_Pueblo1MatsENtregados
  m_EditorClassIdentifier: 
  lineas:
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "\xA1Esto es incre\xEDble!"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Ya estamos un paso m\xE1s cerca de poder celebrar el festival"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Aunque vamos a necesitar una ayudita
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Est\xE1bamos explorando el terreno para hacer los preparativos"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Y nos encontramos con otra criatura en la zona de la playa
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "No se si te has fijado, pero hasta ahora hab\xEDa un camino bloqueado
      con vallas bajo tu granja"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Pues es por esa zona donde aparecieron los problemas
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "As\xED que vamos a abrirte la zona, y espero que puedas ir y hacer todo
      lo que haga falta"
  opciones: []
