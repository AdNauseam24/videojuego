  m_Script: {fileID: 11500000, guid: a7542fd98a6c7a64992f0fe42f2fb690, type: 3}
  m_Name: Cap3_Pueblo1_AyudadoYSegundo
  m_EditorClassIdentifier: 
  lineas:
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Supongo que ya habr\xE1s ido a hablar con nuestros vecinos"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Y habr\xE1s visto que nos han robado el amuleto, aunque hayan decidido
      d\xE1rtelo"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: En fin, pese a todo tengo un favor que pedirte
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Tenemos la intenci\xF3n de celebrar un gran festival"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: Para lo cual necesitamos que nos proveas de los materiales necesarios
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "En este caso ser\xEDan 50 regalos del drag\xF3n y 300 de oro"
  - speaker: {fileID: 11400000, guid: b0e32e4342e6e784aaf3d8c83ea5ca63, type: 2}
    texto: "Te lo agradecer\xEDamos mucho"
  opciones: []
